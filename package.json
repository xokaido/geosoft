{
  "name": "geosoft-chat",
  "private": true,
  "workspaces": [
    "worker",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n worker,web -c blue,green \"npm run dev:worker\" \"npm run dev:frontend\"",
    "dev:worker": "cd worker && wrangler dev",
    "dev:frontend": "cd frontend && vite --port 5173",
    "build": "cd frontend && vite build --outDir ../worker/public && cd ../worker && wrangler deploy",
    "build:frontend": "cd frontend && vite build --outDir ../worker/public",
    "deploy": "cd worker && wrangler deploy",
    "ingest": "npx tsx scripts/ingest-geosoft.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "dotenv": "^16.4.5",
    "node-html-parser": "^6.1.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
